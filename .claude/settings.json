      "Bash(npx *)",
      "Bash(py *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(node *)",
      "Bash(netstat *)",
      "Bash(tasklist *)",
      "Bash(taskkill *)",
      "Bash(pkill *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(rm *)",
      "Bash(cat *)",
      "Bash(curl *)",
      "Bash(sleep *)",
      "Bash(cd *)",
