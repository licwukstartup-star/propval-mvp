# PropVal Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to Git.

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── EPC API ──
EPC_EMAIL=your-email@example.com
EPC_API_KEY=your-epc-api-key

# ── AI / LLM ──
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
CEREBRAS_API_KEY=your-cerebras-api-key

# ── Planning & Land Data ──
PLD_API_KEY=your-pld-api-key

# ── Frontend (also set in frontend/.env.local) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-google-maps-embed-key

# ── Optional ──
# ALLOWED_ORIGINS=http://localhost:3000
# MAINTENANCE_MODE=false
